rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────

    // Returns the caller's user_team_state document (cached per request)
    function myState() {
      return get(/databases/$(database)/documents/user_team_state/$(request.auth.uid)).data;
    }

    // ── World data — read-only from clients ──────────────────────
    // Written only by the Admin SDK (migration script / server).

    match /leagues/{leagueId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /players/{playerId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /staff/{staffId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Teams: readable by all authenticated users.
    // Only the owner of a team can rename it (name propagation).
    match /teams/{teamId} {
      allow read:   if request.auth != null;
      allow update: if request.auth != null
                    && myState().teamId == teamId;
      allow create, delete: if false;
    }

    // ── Shared live data ─────────────────────────────────────────

    // Any authenticated user may update a match to record the result.
    // No one can create or delete match documents from the client.
    match /matches/{matchId} {
      allow read:   if request.auth != null;
      allow update: if request.auth != null;
      allow create, delete: if false;
    }

    // Standings are updated atomically alongside match results.
    match /standings/{standingId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Transfer market ──────────────────────────────────────────

    match /transfer_market/{listingId} {
      allow read:   if request.auth != null;
      // A user may only list players from their own team.
      allow create: if request.auth != null
                    && request.resource.data.sellingTeamId == myState().teamId;
      // Only the selling team's owner may delist.
      allow delete: if request.auth != null
                    && resource.data.sellingTeamId == myState().teamId;
      allow update: if false;
    }

    // ── Per-user data — strictly private ────────────────────────

    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    match /user_team_state/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
