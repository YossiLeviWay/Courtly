rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────

    // Returns true if the caller has isAdmin: true in their users doc.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Returns the caller's user_team_state document (cached per request)
    function myState() {
      return get(/databases/$(database)/documents/user_team_state/$(request.auth.uid)).data;
    }

    // ── World data — read-only from clients ──────────────────────
    // Written only by the Admin SDK (migration script / server).

    match /leagues/{leagueId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /players/{playerId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /staff/{staffId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Teams: readable by all authenticated users.
    // Only the owner of a team (or admin) can rename it.
    match /teams/{teamId} {
      allow read:           if request.auth != null;
      allow update:         if request.auth != null
                            && (myState().teamId == teamId || isAdmin());
      allow create, delete: if isAdmin();
    }

    // ── Shared live data ─────────────────────────────────────────

    // Any authenticated user may update a match to record a result.
    // Only admin can create or delete match documents (schedule regeneration).
    match /matches/{matchId} {
      allow read:           if request.auth != null;
      allow update:         if request.auth != null;
      allow create, delete: if isAdmin();
    }

    // Standings are updated atomically alongside match results.
    match /standings/{standingId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Match logs: written when a match result is recorded, readable by all.
    match /match_logs/{matchId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // App config (season management): only admin can write.
    match /app_config/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Transfer market ──────────────────────────────────────────

    match /transfer_market/{listingId} {
      allow read:   if request.auth != null;
      // A user may only list players from their own team.
      allow create: if request.auth != null
                    && request.resource.data.sellingTeamId == myState().teamId;
      // Only the selling team's owner (or admin) may delist.
      allow delete: if request.auth != null
                    && (resource.data.sellingTeamId == myState().teamId || isAdmin());
      allow update: if false;
    }

    // ── Per-user data — strictly private ────────────────────────

    match /users/{userId} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == userId || isAdmin());
    }

    // Users may only read/write their own state.
    // Admin can read/write any user's state (e.g. to reset seasonRecord).
    match /user_team_state/{userId} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == userId || isAdmin());
    }
  }
}
